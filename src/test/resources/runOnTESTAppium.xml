<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lambda Ecommerce" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="reportConfig.AllureTestListener"/>
    </listeners>
    <parameter name="url" value="https://ecommerce-playground.lambdatest.io"/>
    <test name="Run on iPhone 15" >
        <parameter name="env" value="mobile"/>
        <parameter name="osName" value="ios_15"/>
        <parameter name="browserName" value="mobile_safari"/>
        <classes>
            <class name="tests.TC_Register_iOS_parallel"/>
<!--            <class name="tests.TC_Register_iOS_parallel1"/>-->
        </classes>
    </test>
    <test name="Run on iPhone 15 Pro Max" >
        <parameter name="env" value="mobile"/>
        <parameter name="osName" value="ios_15promax"/>
        <parameter name="browserName" value="mobile_safari"/>
        <classes>
<!--            <class name="tests.TC_Register_iOS_parallel"/>-->
            <class name="tests.TC_Register_iOS_parallel1"/>
        </classes>
    </test>
