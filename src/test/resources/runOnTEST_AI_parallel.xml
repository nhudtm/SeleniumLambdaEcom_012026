<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lambda Ecommerce - TC_Blog Parallel Check" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="reportConfig.AllureTestListener"/>
        <listener class-name="listeners.AnnotationTransformer"/>
    </listeners>

    <parameter name="url" value="https://ecommerce-playground.lambdatest.io"/>

    <test name="Run TC_Blog Parallel - Headless Chrome A">
        <parameter name="browserName" value="hchrome"/>
        <parameter name="env" value="local"/>
        <classes>
            <class name="tests.TC_Blog"/>
        </classes>
    </test>

    <test name="Run TC_Blog Parallel - Headless Chrome B">
        <parameter name="browserName" value="hchrome"/>
        <parameter name="env" value="local"/>
        <classes>
            <class name="tests.TC_Blog"/>
        </classes>
    </test>
</suite>
