<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lambda Ecommerce" >
    <listeners>
        <listener class-name="reportConfig.AllureTestListener"/>
    </listeners>
    <parameter name="url" value="https://ecommerce-playground.lambdatest.io"/>
    <test name="Run on Chrome">
        <parameter name="env" value="browserstack"/>
        <!--        nếu run trên local thì value = local, các parameter bên dưới để vậy cũng không sao, local không cần-->
        <parameter name="browserName" value="chrome"/>
        <parameter name="os" value="Windows"/>
        <parameter name="osVersion" value="11"/>
        <parameter name="browserVersion" value="132"/>
        <classes>
            <class name="tests.TC_Cart"/>
            <class name="tests.TC_Login"/>
            </classes>
    </test>
    <test name="Run on Firefox">
        <parameter name="browserName" value="firefox"/>
        <parameter name="env" value="browserstack"/>
        <!--        nếu run trên local thì value = local, các parameter bên dưới để vậy cũng không sao, local không cần-->
        <parameter name="os" value="Windows"/>
        <parameter name="osVersion" value="11"/>
        <parameter name="browserVersion" value="132.0"/>
        <classes>
            <!--            <class name="tests.TC_Login"/>-->
            <class name="tests.TC_Login"/>
            <class name="tests.TC_Cart"/>
        </classes>
    </test>
    <test name="Run on Safari">
        <parameter name="env" value="browserstack"/>
        <parameter name="browserName" value="safari"/>
        <parameter name="os" value="OS X"/>
        <parameter name="osVersion" value="Sonoma"/>
        <parameter name="browserVersion" value="17.3"/>
        <classes>
            <class name="tests.TC_Login"/>
        </classes>
    </test>

</suite>